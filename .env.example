# ==============================================================================
# OVERDRIVE AI - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to a new file named '.env' in the backend/ directory and populate.
# ==============================================================================

# Server Configuration
PORT=5000

# 1. Gemini Developer API Credentials
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_DEVELOPER_API_KEY_HERE

# 2. Google Workspace API OAuth Integration (Mail, Calendar, Drive)
# Register a Google Cloud Console Project: https://console.cloud.google.com/
# Enable Gmail API, Google Calendar API, and Google Drive API.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/oauth2callback
GOOGLE_REFRESH_TOKEN=your_google_api_refresh_token_here

# 3. Slack Triage Webhook Endpoints
# Create an Incoming Webhook in your Slack Workspace settings:
SLACK_WEBHOOK_URL=your_slack_incoming_webhook_url_here

# 4. Canvas LMS Platform Sync Credentials
# Generate a Access Token inside canvas Account Settings -> Approved Integrations:
CANVAS_LMS_TOKEN=your_canvas_lms_access_token_here
CANVAS_LMS_URL=https://canvas.university.edu
